{
  "name": "careercamp-ai-gateway",
  "version": "1.0.0",
  "description": "CareerCamp AI — World-first career intelligence platform (LLM + VLM + Voice + BERT)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "ml": "python api_server.py",
    "ollama": "ollama serve",
    "setup": "ollama pull tinyllama:1.1b && ollama pull mistral:7b && ollama pull llava:7b",
    "docker": "docker-compose up -d careercamp-gateway ollama",
    "docker:full": "docker-compose --profile full up -d",
    "docker:gpu": "docker-compose --profile gpu up -d"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.7.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.0",
    "groq-sdk": "^0.7.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "career",
    "ai",
    "llm",
    "bert",
    "vision",
    "voice",
    "nlp"
  ],
  "overrides": {
    "protobufjs": "^7.5.9",
    "sharp": "^0.35.3"
  }
}
